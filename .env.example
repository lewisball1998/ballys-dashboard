# Bally's Dashboard environment configuration.
# Copy to `.env` for local dev. All *product* configuration (dashboard name,
# theme, intervals, apps, etc.) is managed in the UI and stored in SQLite —
# these variables only cover deployment-level secrets and paths.

# Runtime mode
NODE_ENV=development

# Port the server listens on
PORT=3000

# Path to the SQLite database file (lives on the mounted data volume in Docker)
DATABASE_PATH=./data/ballys.db

# Encryption key for secrets at rest (module credentials, added in v0.2).
# Optional in v0.1 (no module secrets yet). Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# APP_ENCRYPTION_KEY=
