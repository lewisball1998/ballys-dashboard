# Bally's Dashboard environment configuration.
# Copy to `.env` for local dev. All *product* configuration (dashboard name,
# theme, intervals, apps, auth on/off, etc.) is managed in the UI and stored in
# SQLite — these variables only cover deployment-level concerns.
# Never commit a real .env (it is gitignored).

# Runtime mode
NODE_ENV=development

# Port the server listens on
PORT=3000

# Path to the SQLite database file (lives on the mounted data volume in Docker).
# This file IS your data + backup target — preserve it to keep everything.
DATABASE_PATH=./data/ballys.db

# Where uploaded custom icon files are stored (v0.2.6). Optional: defaults to an
# `icons/` directory next to DATABASE_PATH, so it sits on the same data volume.
# NOTE: with custom icons, your backup target is the whole data dir, not just the
# .db file. Icons are served to the browser by opaque id only — never by path.
# ICONS_DIR=./data/icons

# Auth recovery escape hatch. Set to "1" to BYPASS authentication if you are
# locked out (e.g. forgot the admin password). CSRF/same-origin protection still
# applies. Unset it again once you have recovered.
# AUTH_DISABLE=1

# Docker Command Centre (v0.2). Path to the Docker Engine API unix socket used to
# list and control containers. PRIVILEGED + opt-in: the socket is NOT mounted by
# default. Until it is mounted, the Docker page shows a clear "not configured"
# state. See docs/DOCKER.md before enabling. Default shown below.
# DOCKER_SOCKET_PATH=/var/run/docker.sock

# TrueNAS read-only telemetry (v0.3.2). OPTIONAL: when unset, the Infrastructure
# page shows TrueNAS as "not configured" and works exactly as before. When set,
# it adds read-only NAS pool / dataset / disk / temperature / SMART telemetry.
# It performs NO write actions (no pool/dataset management, no SMART/scrub
# triggers). The API key is used server-side only — never sent to the browser or
# logged. Use a read-only / least-privilege key. See docs/truenas-telemetry.md.
# Never commit a real key (placeholders only below).
# TRUENAS_URL=https://your-truenas-host:443
# TRUENAS_API_KEY=replace-with-your-key
# JSON-RPC WebSocket path on the TrueNAS host (current TrueNAS SCALE API). The
# default suits modern installs; only change it if your version differs.
# TRUENAS_API_PATH=/api/current
# TLS verification bypass for self-signed / trusted-local TrueNAS ONLY. Default is
# false (verify). "true" skips verification for the TrueNAS connection ALONE — it
# never weakens global TLS. Keep false if TrueNAS has a valid or proxied cert.
# TRUENAS_ALLOW_INSECURE=false

# Secret-at-rest encryption key. OPTIONAL/UNUSED in v0.1 (no module credentials
# are stored yet); becomes required in v0.2 when integrations store secrets.
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# APP_ENCRYPTION_KEY=

# NOTE: auth on/off (authEnabled) and the admin account live in the database
# (settings + users tables), configured via the first-run setup wizard — NOT
# via env. Session cookies are marked Secure automatically when the request is
# HTTPS (e.g. behind a TLS reverse proxy); on plain-HTTP LAN they are not Secure.
